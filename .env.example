# ─────────────────────────────────────────────────────────────
# GesGov Backend — Variables de Entorno
# Copia este archivo como .env y completa los valores reales
# ─────────────────────────────────────────────────────────────

# Puerto del servidor
PORT=3001

# MongoDB Atlas URI
# Obtén tu URI en: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# JWT — Cambia el secret por una cadena larga y aleatoria en producción
JWT_SECRET=cambia_este_secret_por_uno_seguro_en_produccion
JWT_EXPIRES_IN=8h

# Tamaño máximo de archivo permitido (en bytes, 10MB = 10485760)
MAX_FILE_SIZE_MB=10

# Ruta local donde se guardan los archivos subidos
UPLOAD_PATH=./uploads

# URL del frontend (para configurar CORS)
# Desarrollo: http://localhost:5173
# Producción: https://tu-dominio.com
FRONTEND_URL=http://localhost:5173
